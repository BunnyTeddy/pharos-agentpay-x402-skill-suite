# Pharos AgentPay x402 Skill Suite
# Copy to .env for local real-mode testing. Never commit real secrets.

# Common
PORT=4020
SKILL_PORT=4020
DEMO_API_PORT=4021
FACILITATOR_PORT=4023
AGENTPAY_MODE=mock

# Pharos Atlantic Testnet defaults
PHAROS_NETWORK=eip155:688689
PHAROS_CHAIN_ID=688689
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
USDC_ADDRESS=0xE0BE08c77f415F577A1B3A9aD7a1Df1479564ec8
USDC_NAME=USDC

# Seller / resource server
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000
FACILITATOR_URL=http://localhost:4023

# Buyer / agent wallet (real mode only)
EVM_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_DO_NOT_COMMIT

# Safety guard for agent payments
MAX_USD_DEFAULT=0.01
