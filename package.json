{
  "name": "pharos-agentpay-x402-skill-suite",
  "version": "0.1.0",
  "description": "Reusable AgentPay x402 Skill Suite for Pharos AI Agent Carnival Phase 1",
  "type": "module",
  "license": "MIT",
  "private": false,
  "bin": {
    "agentpay": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve:skills": "tsx src/cli.ts serve-skills",
    "serve:demo-api": "tsx src/cli.ts serve-demo-api",
    "serve:facilitator": "tsx src/cli.ts serve-facilitator",
    "demo:mock": "tsx src/cli.ts demo --mode mock",
    "demo:real": "tsx src/cli.ts demo --mode real",
    "agentpay": "tsx src/cli.ts"
  },
  "dependencies": {
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "@x402/express": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "viem": "^2.43.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
